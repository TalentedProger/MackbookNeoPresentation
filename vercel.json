{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter \"@workspace/macbook-neo\" build",
  "outputDirectory": "artifacts/macbook-neo/dist/public",
  "functions": {
    "api/index.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
